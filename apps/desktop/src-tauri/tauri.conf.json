{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Desktop Companion Agent",
  "version": "0.0.0",
  "identifier": "com.desktopcompanion.agent",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Desktop Companion Agent",
        "width": 160,
        "height": 160,
        "minWidth": 160,
        "minHeight": 160,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "resizable": false,
        "skipTaskbar": true,
        "shadow": false
      },
      {
        "label": "avatar-library",
        "title": "形象库",
        "width": 420,
        "height": 480,
        "minWidth": 360,
        "minHeight": 420,
        "visible": false,
        "resizable": true,
        "skipTaskbar": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": ["nsis"]
  }
}
