# Local FastAPI service
COMPANION_BACKEND_URL=http://127.0.0.1:18082
COMPANION_DATA_DIR=./backend/data

# automatic | local_only | cloud_preferred
COMPANION_MODE=automatic

# Provider identifiers only. Never put API keys in this file.
COMPANION_CHAT_PROVIDER=openai-compatible
COMPANION_VISION_PROVIDER=
COMPANION_IMAGE_PROVIDER=
